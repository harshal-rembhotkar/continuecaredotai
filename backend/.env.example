# Required: Google Gemini API key from https://aistudio.google.com/apikey
LLM_API_KEY=AIza-your-gemini-api-key

# LLM (defaults shown — usually no need to change)
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash

# Embeddings — must be configured alongside LLM (Cognee requirement)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=AIza-your-gemini-api-key
EMBEDDING_DIMENSIONS=768

# Cognee storage — app handles auth; disable Cognee multi-tenant mode
ENABLE_BACKEND_ACCESS_CONTROL=false

# Hospital staff shared login password (doctors cannot self-register)
HOSPITAL_DOCTOR_PASSWORD=continuecare
